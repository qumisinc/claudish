rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /error_reports/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Model catalog — public read, no client writes (only Cloud Functions write)
    match /models/{modelId} {
      allow read: if true;
      allow write: if false;

      // Changelog subcollection — full change history, public read
      // Tracks ALL field changes: pricing, context windows, capabilities, status
      match /changelog/{changeId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Plugin config — public read, no client writes (only Cloud Functions / console)
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
